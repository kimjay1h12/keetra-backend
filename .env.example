# CORS is currently permissive (any origin) in code. Re-introduce env-based allowlists before locking down production.

# --- WebRTC / TURN (production: use Twilio) ---
# The API GET /api/rtc/ice mints short-lived ICE credentials via Twilio when both vars below are set.
# Docs: https://www.twilio.com/docs/stun-turn/api
#
# Setup:
# 1. Twilio Console → Account → API keys & tokens (or main dashboard) — copy Account SID and Auth Token.
# 2. Set TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN here (and in your host env: Vercel/DigitalOcean/etc.).
# 3. Restart the API. On success, server logs: "ICE config: Twilio Network Traversal (...)".
# 4. Frontend must call the same backend for GET /rtc/ice (authorized); no Twilio secrets in the browser.
#
# If the token request fails, check Twilio account status, credentials, and API permissions; the service falls back to Metered, RTC_ICE_SERVERS_JSON, or public relays.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Ephemeral credential TTL in seconds (600–86400). Default 86400 (24h).
# TWILIO_ICE_TTL_SECONDS=86400

# Metered.ca dynamic TURN (alternative to Twilio; good for cross-network without Twilio):
# METERED_TURN_HOST=yourapp.metered.live
# METERED_TURN_SECRET_KEY=<secret from Metered dashboard>
# Or set the full credential URL instead of HOST + SECRET:
# METERED_TURN_CREDENTIAL_URL=https://yourapp.metered.live/api/v1/turn/credential?secretKey=...

# Optional static ICE (any provider). If Twilio/Metered return no TURN relay, OpenRelay TURN is appended automatically.
# RTC_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:…","username":"…","credential":"…"}]

# --- Public URLs (emails, team share links, meeting schedule emails, absolute avatar URLs) ---
# Set to the origin users open in the browser (your Next.js / frontend), with https in production.
# Example: APP_PUBLIC_URL=https://app.yourdomain.com
# Aliases: FRONTEND_PUBLIC_URL, WEB_APP_URL, PUBLIC_SITE_URL (first set wins)
# APP_PUBLIC_URL=

# --- Outbound email (team invites, scheduled meeting notices) ---
# Turn on after SES or SMTP is configured.
# EMAIL_ENABLED=true
#
# **Option A — Amazon SES (IAM access key)** — preferred if you already use AWS:
# AWS_ACCESS_KEY_ID=...   (alias: AWS_ACCESS_KEY)
# AWS_SECRET_ACCESS_KEY=...   (alias: AWS_SECRET_KEY)
# AWS_REGION=us-east-1   (or AWS_SES_REGION if different from other AWS services)
# AWS_SUPPORT=noreply@yourdomain.com   (must be a verified SES identity; used as From if SMTP_FROM unset)
# Optional explicit From header: SMTP_FROM="KeeTra <noreply@yourdomain.com>"
#
# **Option B — SMTP** (Gmail, etc.):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
# SMTP_FROM="KeeTra <your.address@gmail.com>"
#
# If EMAIL_ENABLED=true but neither block is complete, the API logs a warning and skips sends.
# New SES accounts are often in “sandbox”: verify recipient emails or request production access.

# On Render, `RENDER=true` and `RENDER_EXTERNAL_URL` are set automatically. The app then GETs
# `${RENDER_EXTERNAL_URL}/api` every 10 minutes so inbound HTTP keeps the web service warm.
# Disable: KEEPALIVE_ENABLED=false
# Non-Render: set KEEPALIVE_URL to your full public health URL (e.g. https://api.example.com/api)
# KEEPALIVE_ENABLED=true
# KEEPALIVE_URL=

MONGODB_URI=
JWT_SECRET=
JWT_REFRESH_SECRET=
# Access JWT lifetime (default 24h if unset). Refresh keeps you signed in across access expiry.
# JWT_EXPIRES_IN=24h
# Refresh JWT + server session TTL (default 90d if unset). Longer = stay logged in longer.
# JWT_REFRESH_EXPIRES_IN=90d

# --- Team business mail (self-hosted IMAP/SMTP) ---
# Shown to users in the app as connection instructions.
# TEAM_MAIL_IMAP_HOST=mail.example.com
# TEAM_MAIL_IMAP_PORT=993
# TEAM_MAIL_IMAP_TLS=true
# TEAM_MAIL_SMTP_HOST=mail.example.com
# TEAM_MAIL_SMTP_PORT=587
# TEAM_MAIL_SMTP_TLS=true
# Optional web UI for users
# TEAM_MAIL_WEBMAIL_URL=https://mail.example.com/webmail

# If set, domains equal to this value skip DNS TXT verification (platform-operated hostname).
# TEAM_MAIL_DEFAULT_DOMAIN=mail.yourproduct.com

# Optional HTTP bridge: POST JSON payloads for mailbox.create | mailbox.delete | mailbox.password
# TEAM_MAIL_PROVISION_URL=http://127.0.0.1:4099/mail-provision
# TEAM_MAIL_PROVISION_SECRET=change-me
